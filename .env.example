# ── OpenClaw Gateway ──────────────────────────────────────────────────────────
# URL of your running OpenClaw gateway (default: http://127.0.0.1:18789)
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# Gateway API bearer token (required for authenticated API access)
# OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# ── Discord (optional — alerts, task management) ───────────────────────────
# Bot token for Deck system alerts (budget, drift, stuck loops)
# DISCORD_BOT_TOKEN_DECK=your-discord-bot-token

# Fallback bot token (used if DISCORD_BOT_TOKEN_DECK not set)
# DISCORD_BOT_TOKEN=your-discord-bot-token

# ── Dashboard URLs (optional) ─────────────────────────────────────────────
# Dashboard URL used in Discord notification deep-links
# DECK_URL=http://localhost:3000

# ── Database paths (optional) ─────────────────────────────────────────────
# Override default database locations
# DECK_SYSTEM_LOG_DB=/path/to/deck-system.db
# DECK_USAGE_DB=/path/to/usage.db

# ── Plugin paths (optional) ───────────────────────────────────────────────
# Override the Deck repo root (default: auto-detected from plugin location)
# DECK_ROOT=/path/to/openclaw-deck

# Path to the openclaw CLI binary (default: uses PATH lookup)
# OPENCLAW_BIN=openclaw
